# AskClaw Server Configuration
# Copy to .env and fill in your values

# Database
ASKCLAW_DB_PATH=/var/lib/askclaw/askclaw.db
ASKCLAW_HTPASSWD_PATH=/etc/nginx/.askclaw-users
ASKCLAW_UPLOAD_DIR=/var/lib/askclaw/uploads

# OpenClaw (default AI provider)
ASKCLAW_OPENCLAW_CONFIG=/root/.openclaw/openclaw.json

# Azure OpenAI (optional — overrides default OpenAI provider)
# Uncomment and fill in to route all AI requests through your Azure deployment
# ASKCLAW_AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# ASKCLAW_AZURE_OPENAI_KEY=your-azure-openai-key
# ASKCLAW_AZURE_OPENAI_DEPLOYMENT=gpt-4o
# ASKCLAW_AZURE_OPENAI_API_VERSION=2025-01-01-preview
