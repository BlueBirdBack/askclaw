# AskClaw Server Configuration
# Copy to .env and fill in your values

# Database
ASKCLAW_DB_PATH=/var/lib/askclaw/askclaw.db
ASKCLAW_HTPASSWD_PATH=/etc/nginx/.askclaw-users
ASKCLAW_UPLOAD_DIR=/var/lib/askclaw/uploads

# OpenClaw (default AI provider)
ASKCLAW_OPENCLAW_CONFIG=/root/.openclaw/openclaw.json

